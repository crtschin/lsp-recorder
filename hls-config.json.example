{
  "server_command": "haskell-language-server-wrapper --lsp",
  "trace_out": "hls-trace.jsonl",
  "project_root": "/path/to/your/haskell/project",
  "snapshot": {
    "include": [
      "**/*.hs",
      "**/*.lhs",
      "**/*.cabal",
      "**/package.yaml",
      "cabal.project",
      "cabal.project.local",
      "cabal.project.freeze",
      "stack.yaml",
      "stack.yaml.lock",
      "hie.yaml",
      "Setup.hs",
      "Setup.lhs",
      "fourmolu.yaml"
    ],
    "exclude": [
      "dist-newstyle/**",
      ".stack-work/**",
      ".git/**"
    ]
  }
}
